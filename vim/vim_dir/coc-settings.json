{
    "suggest.noselect": true,

    "rust-client.rlsPath": "/usr/lib/rust/1.60.0/bin/rls",
    "rust-analyzer.rustfmt.rangeFormatting.enable": true,
    "rust-analyzer.rustfmt.extraArgs": ["--edition", "2021"],
    "rust-analyzer.check.command": "clippy",
    "rust-analyzer.cargo.buildScripts.enable": true,
    "rust-analyzer.procMacro.enable": true,
    "rust-analyzer.diagnostics.enable": true,

    "clangd.arguments": [
        "--function-arg-placeholders=false",
        "--header-insertion=iwyu",
        "--completion-style=detailed",
        "--clang-tidy",
        "--malloc-trim",
        "--background-index"
    ],
    "languageserver": {
        "arduino": {
            "command": "/home/vulder/source/arduino-language-server/arduino-language-server",
            "rootPatterns": ["*.ino"],
            "filetypes": ["arduino"],
            "args": ["-cli", "/home/vulder/bin/arduino-cli", "-clangd", "/usr/lib/llvm/11/bin/clangd", "-cli-config", "/home/vulder/.arduino15/arduino-cli.yaml", "-fqbn", "esp8266:esp8266:generic"]
        }
    },
    "diagnostic-languageserver.filetypes": {
        "python": ["pylint", "mypy"]
    }
}
